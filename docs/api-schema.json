{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ExtractionResult",
  "version": "1.0",
  "description": "Schema contract between cascade-agent HTTP API and CascadeIntelligence Swift SDK",
  "type": "object",
  "required": ["entities", "confidence", "modelId", "latencyMs", "requiresReview", "schemaVersion"],
  "properties": {
    "entities": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["type", "displayName", "confidence", "sourceText"],
        "properties": {
          "type": { "type": "string", "enum": ["medication", "condition", "lab", "socialHistory", "vital", "allergy", "immunization", "procedure"] },
          "displayName": { "type": "string" },
          "confidence": { "type": "number", "minimum": 0.0, "maximum": 1.0 },
          "sourceText": { "type": "string" },
          "status": { "type": "string" },
          "normalizedCode": { "type": "string" }
        }
      }
    },
    "confidence": { "type": "number", "minimum": 0.0, "maximum": 1.0 },
    "modelId": { "type": "string" },
    "latencyMs": { "type": "integer" },
    "requiresReview": { "type": "boolean" },
    "schemaVersion": { "type": "string", "const": "1.0" }
  }
}
