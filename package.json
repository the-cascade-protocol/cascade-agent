{
  "name": "@the-cascade-protocol/agent",
  "version": "0.1.4",
  "description": "Natural language interface for the Cascade Protocol CLI",
  "type": "module",
  "bin": {
    "cascade-agent": "dist/cli.js"
  },
  "files": [
