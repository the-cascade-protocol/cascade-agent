    "openai",
    "llm"
  ],
  "license": "MIT",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.55.0",
    "chalk": "^5.4.1",
    "commander": "^13.1.0",
    "openai": "^6.27.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.8.0"
  }
